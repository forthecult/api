{
  "info": {
    "name": "For the Cult API",
    "description": "Shopping API with multi-chain and x402 crypto payments. Quality wellness, smart home, and lifestyle products and gifts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "forthecult"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://forthecult.store/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health & Discovery",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check API health and get version info"
          }
        },
        {
          "name": "Get Capabilities",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/agent/capabilities",
              "host": ["{{baseUrl}}"],
              "path": ["agent", "capabilities"]
            },
            "description": "Get what the API can do for agents"
          }
        },
        {
          "name": "Get Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/categories",
              "host": ["{{baseUrl}}"],
              "path": ["categories"]
            },
            "description": "List all product categories"
          }
        },
        {
          "name": "Get Featured Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/featured",
              "host": ["{{baseUrl}}"],
              "path": ["products", "featured"]
            },
            "description": "Get featured/trending products"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/search?q=dark roasted coffee&sort=newest&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["products", "search"],
              "query": [
                {
                  "key": "q",
                  "value": "dark roasted coffee",
                  "description": "Search query"
                },
                {
                  "key": "category",
                  "value": "mens-tees",
                  "description": "Filter by category",
                  "disabled": true
                },
                {
                  "key": "priceMin",
                  "value": "20",
                  "description": "Min price USD",
                  "disabled": true
                },
                {
                  "key": "priceMax",
                  "value": "50",
                  "description": "Max price USD",
                  "disabled": true
                },
                {
                  "key": "sort",
                  "value": "newest",
                  "description": "Sort: newest (recently added), popular (best seller), rating (best rated), price_asc, price_desc"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Results per page"
                },
                {
                  "key": "offset",
                  "value": "0",
                  "description": "Pagination offset",
                  "disabled": true
                }
              ]
            },
            "description": "Search products with filters"
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/:slug",
              "host": ["{{baseUrl}}"],
              "path": ["products", ":slug"],
              "variable": [
                {
                  "key": "slug",
                  "value": "dark-chocolate",
                  "description": "Product slug"
                }
              ]
            },
            "description": "Get full product details including variants"
          }
        }
      ]
    },
    {
      "name": "Payment Methods",
      "item": [
        {
          "name": "Get all supported payment methods",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payment-methods",
              "host": ["{{baseUrl}}"],
              "path": ["payment-methods"]
            },
            "description": "Get all supported payment methods"
          }
        }
      ]
    },
    {
      "name": "Cart & Shipping",
      "item": [
        {
          "name": "Estimate cart totals",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productId\": \"prod_privacy_book\", \"quantity\": 1 },\n    { \"productId\": \"prod_ethereum_hoodie\", \"variantId\": \"var_navy_l\", \"quantity\": 2 }\n  ],\n  \"shipping\": { \"countryCode\": \"US\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cart/estimate",
              "host": ["{{baseUrl}}"],
              "path": ["cart", "estimate"]
            },
            "description": "Preview subtotal, shipping estimate, and crypto amounts before checkout. Final amounts calculated at checkout."
          }
        },
        {
          "name": "Calculate shipping",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"countryCode\": \"US\",\n  \"items\": [\n    { \"productId\": \"prod_privacy_book\", \"quantity\": 1 },\n    { \"productId\": \"prod_ethereum_hoodie\", \"quantity\": 2 }\n  ],\n  \"orderValueCents\": 9999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/shipping/calculate",
              "host": ["{{baseUrl}}"],
              "path": ["shipping", "calculate"]
            },
            "description": "Exact shipping cost and tax estimate for a cart and destination. Use for accurate totals before checkout."
          }
        }
      ]
    },
    {
      "name": "Checkout",
      "item": [
        {
          "name": "Create Order (Solana USDC)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"prod_esim\",\n      \"variantId\": \"var_black_m\",\n      \"quantity\": 1\n    }\n  ],\n  \"chain\": \"solana\",\n  \"token\": \"USDC\",\n  \"email\": \"user@example.com\",\n  \"shippingAddress\": {\n    \"name\": \"John Doe\",\n    \"line1\": \"123 Main St\",\n    \"city\": \"San Francisco\",\n    \"state\": \"CA\",\n    \"postalCode\": \"94102\",\n    \"country\": \"US\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["checkout"]
            },
            "description": "Create order with Solana USDC payment"
          }
        },
        {
          "name": "Create Order (Bitcoin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"prod_privacy_book\",\n      \"quantity\": 1\n    }\n  ],\n  \"chain\": \"bitcoin\",\n  \"token\": \"BTC\",\n  \"email\": \"user@example.com\",\n  \"shippingAddress\": {\n    \"name\": \"Hal Finney\",\n    \"line1\": \"456 Oak Ave\",\n    \"city\": \"Austin\",\n    \"state\": \"TX\",\n    \"postalCode\": \"78701\",\n    \"country\": \"US\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["checkout"]
            },
            "description": "Create order with Bitcoin payment"
          }
        },
        {
          "name": "Create Order (with Token Discount)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"prod_ethereum_hoodie\",\n      \"variantId\": \"var_navy_l\",\n      \"quantity\": 1\n    }\n  ],\n  \"chain\": \"ethereum\",\n  \"token\": \"USDC\",\n  \"email\": \"holder@example.com\",\n  \"wallet\": \"7xKXtg2CW87d97TXJSDpbD5jBkheTqA83TZRuJosgAsU\",\n  \"walletMessage\": \"<from GET /api/checkout/wallet-verify-message>\",\n  \"walletSignatureBase58\": \"<user signs walletMessage with wallet>\",\n  \"shippingAddress\": {\n    \"name\": \"Token Holder\",\n    \"line1\": \"789 Crypto St\",\n    \"city\": \"Miami\",\n    \"state\": \"FL\",\n    \"postalCode\": \"33101\",\n    \"country\": \"US\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/checkout",
              "host": ["{{baseUrl}}"],
              "path": ["checkout"]
            },
            "description": "Create order with wallet address to verify CULT token holdings and apply discount"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Get Order Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/:orderId/status",
              "host": ["{{baseUrl}}"],
              "path": ["orders", ":orderId", "status"],
              "variable": [
                {
                  "key": "orderId",
                  "value": "order_abc123xyz",
                  "description": "Order ID from checkout"
                }
              ]
            },
            "description": "Check payment and shipping status"
          }
        },
        {
          "name": "Get Order Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/:orderId",
              "host": ["{{baseUrl}}"],
              "path": ["orders", ":orderId"],
              "variable": [
                {
                  "key": "orderId",
                  "value": "order_abc123xyz",
                  "description": "Order ID"
                }
              ]
            },
            "description": "Get full order details including items, payment, and tracking"
          }
        }
      ]
    }
  ],
  "event": []
}
