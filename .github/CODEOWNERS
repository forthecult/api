/src/app/api/webhooks/**                @forthecult/sec
/src/app/api/membership/paypal-webhook/**   @forthecult/sec
/src/app/api/payments/stripe/webhook/**     @forthecult/sec

# Database schema + RLS
/src/db/**                              @forthecult/sec @forthecult/platform
/scripts/migrate-enable-rls-*.sql       @forthecult/sec

# CI/CD, husky, and secret-handling scripts
/.github/workflows/**                   @forthecult/sec
