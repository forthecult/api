#!/bin/sh
# Pre-commit hooks for security and code quality
# Updated with Snyk integration for continuous security monitoring

# Navigate to webapp directory if nested
if [ -d webapp ] && [ -f webapp/package.json ]; then
  cd webapp
fi

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "🔐 Starting security pre-commit checks..."
echo ""

# 1. Run gitleaks to detect secrets (non-blocking, just warnings)
echo "[1/4] Running gitleaks to detect secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks detect --source . --verbose --no-git 2>&1 | head -30
  echo "${YELLOW}⚠️  gitleaks scan complete. Review any findings above.${NC}"
  echo "   Public contract addresses and token mints are expected."
else
  echo "${YELLOW}⚠️  gitleaks not installed. Skipping secret scan.${NC}"
fi
echo ""

# 2. Run npm audit (non-blocking warning)
echo "[2/4] Running npm audit..."
npm audit --audit-level=high 2>&1 | head -15 || true
echo "${YELLOW}⚠️  Run 'npm audit' for full details if warnings above.${NC}"
echo ""

# 3. SNYK SCA SCAN: Block commits introducing high/critical vulnerabilities
echo "[3/4] Running Snyk SCA scan (blocking on HIGH/CRITICAL)..."
SNYK_HIGH_CRITICAL_COUNT=0
if command -v npx >/dev/null 2>&1; then
  # Run Snyk test via npx with timeout to prevent hanging
  SNYK_OUTPUT=$(cd /tmp && timeout 60 npx -y snyk@latest test --severity-threshold=high --json 2>/dev/null) || true
  if [ -n "$SNYK_OUTPUT" ] && command -v jq >/dev/null 2>&1; then
    SNYK_HIGH_CRITICAL_COUNT=$(echo "$SNYK_OUTPUT" | jq '[.vulnerabilities[]? | select(.severity == "high" or .severity == "critical")] | length' 2>/dev/null || echo "0")
    if [ "$SNYK_HIGH_CRITICAL_COUNT" -gt 0 ] 2>/dev/null; then
      echo "${RED}❌ Snyk found $SNYK_HIGH_CRITICAL_COUNT HIGH/CRITICAL vulnerabilities:${NC}"
      echo "$SNYK_OUTPUT" | jq -r '.vulnerabilities[]? | select(.severity == "high" or .severity == "critical") | "   \(.severity | ascii_upcase): \(.packageName)@\(.version) - \(.title)"' 2>/dev/null | head -10
      echo ""
      echo "${RED}❌ Commit blocked due to HIGH/CRITICAL vulnerabilities.${NC}"
      echo "   Fix vulnerabilities before committing, or use --no-verify to skip (not recommended)."
      exit 1
    else
      echo "${GREEN}✅ No HIGH/CRITICAL vulnerabilities found by Snyk.${NC}"
    fi
  else
    echo "${YELLOW}⚠️  Snyk scan incomplete. Ensure npm/npx is available and Snyk is authenticated.${NC}"
  fi
else
  echo "${YELLOW}⚠️  npx not available. Skipping Snyk scan.${NC}"
fi
echo ""

# 4. Run typecheck - THIS IS BLOCKING to prevent broken code
echo "[4/4] Running typecheck..."
bun run typecheck
if [ $? -ne 0 ]; then
  echo "${RED}❌ Type errors found. Fix before committing.${NC}"
  exit 1
fi

echo "${GREEN}✅ All pre-commit security checks passed!${NC}"
