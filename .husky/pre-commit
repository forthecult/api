#!/bin/sh
# Pre-commit hooks for security and code quality

# Navigate to webapp directory if nested
if [ -d webapp ] && [ -f webapp/package.json ]; then
  cd webapp
fi

# 1. Run gitleaks to detect secrets (non-blocking, just warnings)
echo "🔍 Running gitleaks to detect secrets..."
if command -v gitleaks >/dev/null 2>&1; then
  gitleaks detect --source . --verbose --no-git 2>&1 | head -30
  echo "⚠️  gitleaks scan complete. Review any findings above."
  echo "    Public contract addresses and token mints are expected."
  echo "    Commit with --no-verify to skip if needed."
else
  echo "⚠️  gitleaks not installed. Skipping secret scan."
fi

# 2. Run security audit on dependencies (non-blocking warning)
echo "🔍 Running dependency audit..."
if command -v bun >/dev/null 2>&1; then
  bun audit --audit-level=high 2>&1 | head -10 || true
  echo "⚠️  Run 'bun audit' for full details if warnings above."
fi

# 3. Run typecheck - THIS IS BLOCKING to prevent broken code
echo "🔍 Running typecheck..."
bun run typecheck
if [ $? -ne 0 ]; then
  echo "❌ Type errors found. Fix before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed!"
