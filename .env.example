# Database (required for app)
# DATABASE_URL=postgres://...

# Amazon Creators API (optional — enables marketplace product search and checkout)
# Get credentials from Associates Central → Tools → Creators API
# AMAZON_CREDENTIAL_ID=
# AMAZON_CREDENTIAL_SECRET=
# AMAZON_PARTNER_TAG=yourstore-20
# AMAZON_MARKETPLACE=www.amazon.com
# AMAZON_API_VERSION=2.1  # 2.1 for NA, 2.2 for EU, 2.3 for FE
