# Database (required for app)
# DATABASE_URL=postgres://...
# DATABASE_POOL_SIZE=5   # optional; default prod 5, dev 20. Lower if you see "Max client connections".

# Amazon Creators API (optional — enables marketplace product search and checkout)
# Get credentials from Associates Central → Tools → Creators API
# AMAZON_CREDENTIAL_ID=
# AMAZON_CREDENTIAL_SECRET=
# AMAZON_PARTNER_TAG=yourstore-20
# AMAZON_MARKETPLACE=www.amazon.com
# AMAZON_API_VERSION=2.1  # 2.1 for NA, 2.2 for EU, 2.3 for FE

# CULT staking (optional — immutable native program)
# CULT_STAKING_PROGRAM_ID=8QZ3EZYFXET2et4bTDoxfQMJTjhRqYTaJbSQf5eEX8Zk

# Stripe (subscription & card payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...                   # for order payment webhooks
# STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=whsec_...       # for membership subscription webhooks
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
#
# Membership subscription price IDs (create in Stripe Dashboard → Products → Prices)
# If these are omitted, the app auto-creates prices via Stripe API on first use.
# STRIPE_PRICE_BASE_MONTHLY=price_...      # BASE tier  $5/mo
# STRIPE_PRICE_BASE_ANNUAL=price_...       # BASE tier  $54/yr (10% off)
# STRIPE_PRICE_PRIME_MONTHLY=price_...     # PRIME tier $10/mo
# STRIPE_PRICE_PRIME_ANNUAL=price_...      # PRIME tier $108/yr (10% off)
# STRIPE_PRICE_APEX_MONTHLY=price_...      # APEX tier  $20/mo
# STRIPE_PRICE_APEX_ANNUAL=price_...       # APEX tier  $216/yr (10% off)
#
# Public price IDs (used on the frontend for display — optional, same values as above)
# NEXT_PUBLIC_STRIPE_PRICE_BASE_MONTHLY=price_...
# NEXT_PUBLIC_STRIPE_PRICE_BASE_ANNUAL=price_...
# NEXT_PUBLIC_STRIPE_PRICE_PRIME_MONTHLY=price_...
# NEXT_PUBLIC_STRIPE_PRICE_PRIME_ANNUAL=price_...
# NEXT_PUBLIC_STRIPE_PRICE_APEX_MONTHLY=price_...
# NEXT_PUBLIC_STRIPE_PRICE_APEX_ANNUAL=price_...
# PayPal (optional — membership subscriptions via PayPal Billing)
# PAYPAL_MODE=live
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=                    # webhook id from dashboard (for signature verification)
# PAYPAL_SKIP_WEBHOOK_VERIFY=true       # dev only — skip signature verification
# PAYPAL_API_BASE=                      # override default api-m.paypal.com / sandbox
#
# Billing plan ids (create in PayPal → Products → Subscriptions → Billing plans)
# PAYPAL_PLAN_BASE_MONTHLY=
# PAYPAL_PLAN_BASE_ANNUAL=
# PAYPAL_PLAN_PRIME_MONTHLY=
# PAYPAL_PLAN_PRIME_ANNUAL=
# PAYPAL_PLAN_APEX_MONTHLY=
# PAYPAL_PLAN_APEX_ANNUAL=


# Venice AI (store chat + RAG embeddings; keep secret server-side)
# VENICE_API_KEY=
# VENICE_DEFAULT_MODEL=llama-3.3-70b
# VENICE_DEFAULT_CHARACTER=
# VENICE_EMBEDDING_MODEL=text-embedding-bge-m3

# Public GitHub URLs for /open-source (optional overrides)
# NEXT_PUBLIC_GITHUB_WEBSITE=
# NEXT_PUBLIC_GITHUB_SMART_CONTRACTS=
# NEXT_PUBLIC_GITHUB_AI=
# NEXT_PUBLIC_GITHUB_MOBILE=
