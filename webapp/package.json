{
  "name": "culture-webapp",
  "description": "Culture storefront — Next.js webapp for forthecult.store.",
  "version": "1.4.6",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run scripts/conditional-build.ts",
    "start": "next start",
    "dev": "next dev -p 3000",
    "dev:turbo": "next dev --turbopack -p 3000",
    "db:migrate-printful": "psql $DATABASE_URL -f scripts/migrate-printful-schema.sql",
    "db:migrate-printful-printify-sync": "psql $DATABASE_URL -f scripts/migrate-printful-printify-sync.sql && psql $DATABASE_URL -f scripts/migrate-variant-composite-unique.sql",
    "db:ensure-printful-printify": "bun run scripts/ensure-printful-printify-columns.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:migrate:shared": "bun run scripts/run-psql-migration.ts drizzle/0007_order_attribution_ad_conversion.sql",
    "db:seed-products": "bun run scripts/seed-products.ts",
    "db:seed-categories": "bun run scripts/seed-categories.ts",
    "db:seed-brands": "bun run scripts/seed-brands.ts",
    "db:upload-brand-assets": "bun run scripts/upload-brand-assets.ts",
    "db:upload-lookbook": "bun run scripts/upload-lookbook-to-uploadthing.ts",
    "db:upload-product-mockups": "bun run scripts/upload-product-mockups.ts",
    "db:upload-curated-product-images": "bun run scripts/upload-curated-product-images.ts",
    "db:delete-seed-product-images": "bun run scripts/delete-seed-product-images.ts",
    "db:seed-and-upload-curated": "bun run scripts/seed-products.ts && bun run scripts/upload-curated-product-images.ts",
    "db:fix-seed-images": "bun run scripts/delete-seed-product-images.ts && bun run scripts/seed-products.ts && bun run scripts/upload-curated-product-images.ts",
    "fetch-brand-assets": "bun run scripts/fetch-brand-assets.ts",
    "db:extract-reviews": "bun run scripts/extract-reviews-seed.ts",
    "db:seed-reviews": "bun run scripts/seed-reviews.ts",
    "db:link-orphan-reviews": "bun run scripts/link-orphan-reviews.ts",
    "db:migrate-reviews": "psql $DATABASE_URL -f scripts/migrate-reviews-standalone.sql",
    "db:migrate-user-role": "psql $DATABASE_URL -f scripts/migrate-add-user-role.sql",
    "db:migrate-esim-order-guest": "psql $DATABASE_URL -f scripts/migrate-esim-order-user-id-nullable.sql",
    "db:migrate-support-chat-source": "psql $DATABASE_URL -f scripts/migrate-support-chat-source.sql",
    "db:migrate-cart-snapshot": "bun run scripts/run-psql-migration.ts scripts/migrate-shopping-cart-snapshot.sql",
    "db:migrate-user-crm-profile": "bun run scripts/run-psql-migration.ts scripts/migrate-user-crm-profile.sql",
    "db:migrate-email": "bun run scripts/run-psql-migration.ts scripts/migrate-email-tables.sql",
    "db:migrate-rls": "bun run scripts/run-psql-migration.ts scripts/migrate-enable-rls-auth-tables.sql",
    "db:migrate-email-foundation": "bun run db:migrate-email && bun run db:migrate-rls",
    "db:migrate-acquisition": "bun run scripts/run-psql-migration.ts drizzle/0007_order_attribution_ad_conversion.sql",
    "db:verify-role": "bun run scripts/verify-role-migration.ts",
    "db:health-check": "bun run scripts/health-check.ts",
    "db:seed-admin": "bun run scripts/seed-admin-user.ts",
    "db:seed:all": "bun run scripts/seed-categories.ts && bun run scripts/seed-products.ts",
    "db:seed:staging": "bun run scripts/seed-categories.ts && bun run scripts/seed-brands.ts && bun run scripts/seed-shipping-by-brand.ts && bun run scripts/seed-products.ts && bun run scripts/seed-reviews.ts",
    "db:seed:production": "bun run scripts/seed-categories.ts && bun run scripts/seed-brands.ts && bun run scripts/seed-shipping-by-brand.ts && bun run scripts/seed-reviews.ts",
    "db:backfill-order-status": "bun run scripts/backfill-order-status.ts",
    "db:migrate-category-ids": "bun run scripts/migrate-category-ids-to-seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:auth": "bun src/lib/auth-db.ts",
    "ui": "bunx --bun shadcn@latest add",
    "latest": "bun update --latest && bun check",
    "typecheck": "tsc --noEmit",
    "check": "tsc --noEmit && eslint --cache --fix . && biome check --fix --unsafe . && knip",
    "check:imports": "bun -e \"import {readFileSync} from 'node:fs'; const dirs=['src','admin/src']; const bad=[]; for (const dir of dirs) { for await (const f of new Bun.Glob('**/*.{ts,tsx,js,jsx,mts,cts}').scan({cwd: dir})) { const p=dir + '/' + f; const t=readFileSync(p,'utf8'); if (/from\\\\s+[\\\"']radix-ui[\\\"']/.test(t)) bad.push(p); } } if (bad.length) { console.error('Invalid import specifier: use @radix-ui/* packages, not radix-ui.'); for (const p of bad) console.error(' - ' + p); process.exit(1); } console.log('Import specifiers OK');\"",
    "generate:openapi": "bun run scripts/generate-openapi.ts",
    "printful:sync": "bun run scripts/printful-sync-products.ts",
    "printful:resync": "bun run scripts/printful-resync-products.ts",
    "printful:update-seo": "bun run scripts/update-printful-products-seo.ts",
    "lions-mane:update-seo": "bun run scripts/update-lions-mane-product-seo.ts",
    "printify:sync": "bun run scripts/printify-sync-products.ts",
    "db:list-products": "bun run scripts/list-products.ts",
    "buyback-burn": "bun run scripts/buyback-burn.ts",
    "vanity:grind": "bun run scripts/solana-vanity-grind.ts",
    "vanity:export-key": "bun run scripts/export-keypair-base58.ts",
    "db:crawl-brand-shipping": "bun run scripts/crawl-brand-shipping.ts",
    "db:seed-shipping-by-brand": "bun run scripts/seed-shipping-by-brand.ts",
    "db:seed-bon-charge": "bun run scripts/seed-bon-charge-via-api.ts",
    "tests": "bun test ./.tests",
    "test:review-normalization": "bun test ./.tests/review-normalization.test.ts",
    "smoketest": "playwright test",
    "smoketest:ci": "next build && CI=1 playwright test",
    "smoke:core": "CI=1 playwright test e2e/smoke.spec.ts --project=chromium --grep @core",
    "smoke:extended": "CI=1 playwright test e2e/smoke.spec.ts --project=chromium --grep @extended",
    "smoke:web3": "CI=1 playwright test e2e/smoke.spec.ts --project=chromium --grep @web3",
    "smoke:staging": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/smoke.spec.ts --project=chromium --grep @core",
    "smoke:staging:extended": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/smoke.spec.ts --project=chromium --grep @extended",
    "smoke:staging:web3": "PLAYWRIGHT_SKIP_WEBSERVER=1 CI=1 playwright test e2e/smoke.spec.ts --project=chromium --grep @web3",
    "smoketest:no-compile": "playwright test --reuse-existing-server",
    "smoketest:ui": "playwright test --ui",
    "email:templates-check": "bun run scripts/render-email-templates.ts",
    "check:deploy-policies": "bun run scripts/enforce-deploy-policies.ts",
    "email:test": "bun run scripts/send-test-email.ts",
    "prepare": "husky",
    "lh:store": "bash -c 'test -n \"$LIGHTHOUSE_URL\" || { echo \"Set LIGHTHOUSE_URL to a full PDP or PLP URL (e.g. http://localhost:3000/your-product)\"; exit 1; }; exec bunx lighthouse \"$LIGHTHOUSE_URL\" --only-categories=performance --chrome-flags=\"--headless=new\" --preset=desktop --output=html --output-path=./lighthouse-store.html'",
    "analyze": "ANALYZE=true bun run build",
    "discord-gateway": "bun run src/scripts/discord-gateway-worker.ts"
  },
