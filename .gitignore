node_modules/
.next/
dist/
build/
# Environment variables — never commit secrets
.env
.env.local
.env.*
!.env.example
*.log
.DS_Store

# tooling caches (regenerated locally — shouldn't ever be committed)
.eslintcache
tsconfig.tsbuildinfo

# This project uses bun (bun.lock). Stale npm/yarn/pnpm lockfiles confuse
# SCA scanners (grype, snyk, npm audit) and produce false-positive CVEs.
package-lock.json
yarn.lock
pnpm-lock.yaml

# Playwright
/test-results/
/playwright-report/
/playwright/.cache/
/e2e/.auth/
