{
  "$schema": "https://docs.openclaw.ai/schema/openclaw.json",

  "gateway": {
    "port": 8080,
    "bind": "0.0.0.0",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    },
    "http": {
      "endpoints": {
        "chatCompletions": {
          "enabled": true
        }
      }
    },
    "reload": {
      "mode": "hybrid"
    }
  },

  "models": {
    "providers": {
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}"
      },
      "openai": {
        "apiKey": "${OPENAI_API_KEY}"
      }
    }
  },

  "agents": {
    "defaults": {
      "model": "claude-4-sonnet",
      "workspace": "/data/workspace",

      "memorySearch": {
        "enabled": true,
        "provider": "openai",
        "model": "text-embedding-3-small",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3,
            "candidateMultiplier": 4
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        },
        "experimental": {
          "sessionMemory": true
        },
        "sources": ["memory", "sessions"]
      },

      "compaction": {
        "reserveTokensFloor": 20000,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 4000,
          "systemPrompt": "Session nearing compaction. Store durable memories now.",
          "prompt": "Write any lasting customer preferences, order context, or important notes to memory/YYYY-MM-DD.md; reply with NO_REPLY if nothing to store."
        }
      }
    },

    "main": {
      "name": "Alice",
      "model": "claude-4-sonnet",
      "fallbackModels": ["gpt-4o", "claude-3.5-haiku"],
      "systemPromptFile": "SOUL.md",
      "agentsFile": "AGENTS.md",
      "toolsFile": "TOOLS.md"
    }
  },

  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [],
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    },

    "discord": {
      "enabled": true,
      "botToken": "${DISCORD_BOT_TOKEN}",
      "groups": {
        "*": {
          "requireMention": true
        }
      }
    },

    "whatsapp": {
      "enabled": false,
      "allowFrom": []
    }
  },

  "messages": {
    "groupChat": {
      "mentionPatterns": ["@alice", "@Alice"]
    }
  },

  "session": {
    "mainKey": "sender",
    "ttl": "7d"
  },

  "memory": {
    "backend": "default",
    "citations": "auto"
  }
}
