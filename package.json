{
  "name": "relivator",
  "description": "Relivator is a robust eCommerce template built with Next.js. It's designed for developers who want a fast, modern, and scalable foundation without reinventing the backend.",
  "version": "1.4.6",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "next build",
    "start": "next start",
    "dev": "next dev -p 3000",
    "dev:turbo": "next dev --turbopack -p 3000",
    "db:migrate-printful": "psql $DATABASE_URL -f scripts/migrate-printful-schema.sql",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run scripts/seed-products.ts",
    "db:seed-categories": "bun run scripts/seed-categories.ts",
    "db:seed-brands": "bun run scripts/seed-brands.ts",
    "db:seed-admin": "bun run scripts/seed-admin-user.ts",
    "db:seed:all": "bun run scripts/seed-categories.ts && bun run scripts/seed-products.ts",
    "db:seed:staging": "bun run scripts/seed-categories.ts && bun run scripts/seed-brands.ts && bun run scripts/seed-products.ts",
    "db:backfill-order-status": "bun run scripts/backfill-order-status.ts",
    "db:migrate-category-ids": "bun run scripts/migrate-category-ids-to-seed.ts",
    "db:studio": "drizzle-kit studio",
    "db:auth": "bun src/lib/auth-db.ts",
    "ui": "bunx --bun shadcn@latest add",
    "latest": "bun update --latest && bun check",
    "check": "tsc --noEmit && eslint --cache --fix . && biome check --fix --unsafe . && knip",
    "generate:openapi": "bun run scripts/generate-openapi.ts",
    "printful:sync": "bun run scripts/printful-sync-products.ts",
    "printify:sync": "bun run scripts/printify-sync-products.ts",
    "db:list-products": "bun run scripts/list-products.ts",
    "db:crawl-brand-shipping": "bun run scripts/crawl-brand-shipping.ts",
    "db:seed-shipping-by-brand": "bun run scripts/seed-shipping-by-brand.ts",
    "tests": "bun test ./.tests"
  },
  "dependencies": {
    "@metamask/sdk-react": "^0.33.1",
    "@mysten/dapp-kit": "^1.0.1",
    "@mysten/payment-kit": "^0.1.0",
    "@mysten/sui": "^2.2.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@pump-fun/pump-swap-sdk": "^1.13.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@solana/client": "^1.7.0",
    "@solana/kit": "^6.0.1",
    "@solana/pay": "^0.2.6",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-wallets": "^0.19.37",
    "@solana/web3-compat": "^0.0.21",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-form": "^1.28.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/table-core": "^8.21.3",
    "@uploadthing/react": "^7.3.3",
    "@vercel/speed-insights": "^1.3.1",
    "better-auth": "1.4.18",
    "bignumber.js": "^9.3.1",
    "bs58": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.33.0",
    "fs-extra": "^11.3.3",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "ofetch": "^1.5.1",
    "pathe": "^2.0.3",
    "pg": "^8.18.0",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-day-picker": "9.13.0",
    "react-dom": "^19.2.4",
    "resend": "^6.9.1",
    "sanitize-html": "^2.17.0",
    "sharp": "^0.34.5",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "swagger-ui-react": "^5.31.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tweetnacl": "^1.0.3",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "viem": "^2.45.1",
    "wagmi": "^3.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "pino-pretty": "^13.1.3",
    "@eslint-react/eslint-plugin": "^2.10.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.8",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.1",
    "@types/pg": "^8.16.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/parser": "^8.54.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-readable-tailwind": "^3.0.0",
    "execa": "^9.6.1",
    "cheerio": "^1.2.0",
    "knip": "^5.83.0",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "overrides": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
