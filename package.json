    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.0",
    "fs-extra": "^11.3.3",
    "lucide-react": "^0.564.0",
    "nanoid": "^5.0.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.8",
    "ofetch": "^1.5.1",
    "pathe": "^2.0.3",
    "postgres": "^3.4.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-day-picker": "^9.13.2",
    "react-dom": "^19.2.4",
    "resend": "^6.9.2",
    "sanitize-html": "^2.17.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.3.1",
    "swagger-ui-react": "^5.31.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tweetnacl": "^1.0.3",
    "uploadthing": "^7.7.4",
    "vaul": "^1.1.2",
    "viem": "^2.46.0",
    "wagmi": "^3.4.3",
    "x402-next": "^1.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@biomejs/biome": "^2.3.15",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/bun": "^1.3.9",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/parser": "^8.55.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.2",
    "eslint-plugin-perfectionist": "^5.5.0",
    "eslint-plugin-readable-tailwind": "^3.0.0",
    "execa": "^9.6.1",
    "husky": "^9.1.7",
